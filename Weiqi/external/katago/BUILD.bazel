load("@rules_cc//cc:defs.bzl", "cc_library", "cc_binary")

package(default_visibility = ["//visibility:public"])

cc_binary(
    name = "libkatago_opencl.so",
    srcs = ["external/opencl/opencl_proxy.cpp"],
    linkshared = 1,
    linkopts = ["-ldl"],
    deps = [":opencl_headers"],
)

cc_library(
    name = "opencl_headers",
    hdrs = glob(["external/opencl/include/CL/CL/*.h"]),
    includes = ["external/opencl/include/CL"],
)

cc_library(
    name = "opencl",
    srcs = [":libkatago_opencl.so"],
    deps = [":opencl_headers"],
)

cc_library(
    name = "katago_lib",
    srcs = glob(
        [
            "cpp/core/*.cpp",
            "cpp/game/*.cpp",
            "cpp/dataio/*.cpp",
            "cpp/neuralnet/*.cpp",
            "cpp/book/*.cpp",
            "cpp/search/*.cpp",
            "cpp/program/*.cpp",
        ],
        exclude = [
            "cpp/neuralnet/cudabackend.cpp",
            "cpp/neuralnet/cudautils.cpp",
            "cpp/neuralnet/trtbackend.cpp",
            "cpp/neuralnet/metalbackend.cpp",
            "cpp/neuralnet/openclbackend.cpp",
            "cpp/neuralnet/openclkernels.cpp",
            "cpp/neuralnet/openclhelpers.cpp",
            "cpp/neuralnet/opencltuner.cpp",
            "cpp/neuralnet/dummybackend.cpp",
            "cpp/main.cpp",
        ],
    ) + [
        "cpp/neuralnet/openclbackend.cpp",
        "cpp/neuralnet/openclkernels.cpp",
        "cpp/neuralnet/openclhelpers.cpp",
        "cpp/neuralnet/opencltuner.cpp",
        "cpp/version.cpp",
    ],
    hdrs = glob([
        "cpp/**/*.h",
        "cpp/**/*.hpp",
        "cpp/external/**/*.h",
        "cpp/external/**/*.hpp",
        "cpp/**/*.opencl",
    ]),
    includes = [
        "cpp",
        "cpp/external",
        "cpp/external/tclap-1.2.5/include",
        "cpp/external/filesystem-1.5.8/include",
        "cpp/external/half-2.2.0/include",
        "external/opencl/include/CL",
    ],
    defines = [
        "USE_OPENCL_BACKEND",
        "NO_GIT_REVISION",
        "NO_LIBZIP",
        "LITTLE_ENDIAN=1234",
        "BIG_ENDIAN=4321",
        "BYTE_ORDER=1234",
        "BUILD_DISTRIBUTED=0",
    ],
    deps = [
        ":opencl",
        "@bazel_tools//tools/cpp:malloc",
        "@protobuf//:protobuf",
        "@zlib//:zlib",
        "@eigen_repo//:eigen",
    ],
)
